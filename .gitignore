*.code-workspace
*.env
.vscode/
nextcloud-stack/data/
FileServerData/
dockersecrets.ps1
logs/
*.img
.terraform.lock.hcl
.terraform/
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (where secrets live)
*.tfvars
*.tfvars.json

# Except for an example file
!example.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

ssh_config

# Ignore Ansible inventory file (generated by Terraform)
# ./ansible-inventory/inventory.ini
secrets.*
*.pem